# Copy to `.env` and fill in. The web app and CLI need NONE of these — they are
# only used by the one-time Notion importer (scripts/import_from_notion.py).

# Notion internal-integration token (the integration must be shared with the DB).
NOTION_TOKEN=
# The Notion database ID to import from.
NOTION_DATABASE_ID=

# Optional overrides
# INVENTORY_DB=/absolute/path/to/inventory.db
# INVENTORY_HOST=0.0.0.0
# INVENTORY_PORT=8502
